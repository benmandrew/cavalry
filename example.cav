// Compute q = x / y and r = x % y by repeated subtraction.
procedure euclidean_div () =
  requires { x >= 0 }
  ensures { x = q * y + r && 0 <= r && r < y }
  writes { q, r }
  q := 0;
  r := x;
  while r >= y do
    invariant { x = q * y + r && 0 <= r } // loop invariant, proved on every iteration
    r := r - y;
    q := q + 1
  end
end

{ true }
x := 42;
y := 17;
q := 0;
r := 0;
euclidean_div();
print(q);
print(r)
{ q = 2 && r = 8 } // 42 = 2 * 17 + 8
