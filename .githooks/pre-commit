#!/bin/sh
# Keep the README's generated snippet SVGs in sync with their sources.
#
# Enable once per clone:   git config core.hooksPath .githooks
#
# Runs assets/readme-snippets/gen.mjs --check, but only when a staged change could
# affect the generated snippets, so unrelated commits pay nothing.

if git diff --cached --name-only | grep -qE '^(assets/readme-snippets/|assets/snippet-.*\.svg$|editors/vscode/syntaxes/cavalry\.tmLanguage\.json$|\.vscode/settings\.json$|README\.md$)'; then
  dir="assets/readme-snippets"
  if [ ! -d "$dir/node_modules" ]; then
    echo "pre-commit: $dir/node_modules is missing — run 'npm ci' in $dir first." >&2
    exit 1
  fi
  if ! (cd "$dir" && npm run --silent check); then
    echo "pre-commit: README snippets are out of date." >&2
    echo "            Run 'npm run build' in $dir and stage the result." >&2
    exit 1
  fi
fi
