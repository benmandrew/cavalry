// Sum 0 + 1 + ... + (n-1), the (n-1)th triangle number. The invariant is
// phrased as 2*x = ... so the proof stays over integers and avoids division.
{ x = 0 && i = 0 && n >= 0 }
while i < n do
  // twice the running sum equals i*(i-1); i has climbed no further than n
  invariant { 2 * x = i * (i - 1) && 0 <= i && i <= n }
  variant { n - i }
  x := x + i;
  i := i + 1
end;
x
{ 2 * x = n * (n - 1) }
