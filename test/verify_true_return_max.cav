// A value-returning procedure: the result binder `r` (declared in `returns`)
// is assigned in the body, and `x := max(...)` binds the call's result.
procedure max (a, b) returns { r : int } =
  requires { true }
  ensures { r >= a && r >= b && (r = a || r = b) }
  writes { }
  if a >= b then r := a else r := b end
end

{ true }
m := max(3, 7)
{ m = 7 }
